# Copy to .env.local for local development — never commit .env.local

# Resend (transactional email)
RESEND_API_KEY=
# Verified sender, e.g. "R.O.P. <livre@votredomaine.com>"
RESEND_FROM=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price ID of the "Livre en ligne" product (one-time payment), e.g. price_123
STRIPE_PRICE_ID=
# Optional — only needed if you later use Stripe.js on the client
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Database (Neon Postgres) — reserved, not currently used
DATABASE_URL=

# Auth (magic-link + access cookie JWT signing) — use a long random string
AUTH_SECRET=

# Google Apps Script webhook that appends rows to the Google Sheet
# (leads, events, visits, purchases)
APPS_SCRIPT_URL=

# Absolute site origin, no trailing slash, e.g. https://livre.example.com
# Used to build Stripe success/cancel URLs and magic links.
NEXT_PUBLIC_BASE_URL=

# Set to "true" to turn the online-book card into a real Stripe checkout.
# Leave unset/false to keep the "notify me" storefront while you finish setup.
NEXT_PUBLIC_BOOK_ON_SALE=
