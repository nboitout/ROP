# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Database (Neon Postgres)
DATABASE_URL=

# Auth (magic-link JWT signing)
AUTH_SECRET=

# Admin dashboard password
ADMIN_PASSWORD=
