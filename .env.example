# Copy to .env.local for local development — never commit .env.local

# Public site URL used for canonical links, sitemap, and social cards
NEXT_PUBLIC_SITE_URL=https://guy-boitout.com

# Resend (transactional email)
RESEND_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Database (Neon Postgres)
DATABASE_URL=

# Auth (magic-link JWT signing)
AUTH_SECRET=

# Admin dashboard password
ADMIN_PASSWORD=

# Azure RAG search
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_ADMIN_KEY=
AZURE_SEARCH_QUERY_KEY=
AZURE_SEARCH_INDEX=rop-book

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5.6-terra
